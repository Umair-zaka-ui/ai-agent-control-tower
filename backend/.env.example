# ---------------------------------------------------------------------------
# AI Agent Control Tower - Environment configuration
# Copy this file to `.env` and adjust the values for your local machine.
# ---------------------------------------------------------------------------

# Human readable project name (shown in Swagger).
PROJECT_NAME=AI Agent Control Tower

# PostgreSQL connection string (local development).
# Format: postgresql+psycopg2://<user>:<password>@<host>:<port>/<database>
DATABASE_URL=postgresql+psycopg2://postgres:<your_password>@localhost:5432/ai_agent_control_tower

# JWT settings. Generate a strong secret for anything beyond local dev, e.g.:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=change-me-in-production-please-use-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# CORS origins (comma separated) for the future dashboard frontend.
BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ---------------------------------------------------------------------------
# Phase 2 settings
# ---------------------------------------------------------------------------

# Prefix used for agent API keys (e.g. agt_live_xxxxx).
API_KEY_PREFIX=agt_live_

# Email notifications (SMTP). Disabled by default for local dev: when false,
# notifications are logged instead of sent. Use Mailtrap for development.
NOTIFICATIONS_ENABLED=false
SMTP_HOST=sandbox.smtp.mailtrap.io
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=no-reply@control-tower.local
SMTP_USE_TLS=true

# ---------------------------------------------------------------------------
# Phase 4.2.2.2 settings — session lifecycle (SRS §11, §12)
# ---------------------------------------------------------------------------

# Idle timeout: no request for this long and the session becomes unusable.
SESSION_IDLE_TIMEOUT_SECONDS=1800
# Absolute ceiling, regardless of activity.
SESSION_ABSOLUTE_TIMEOUT_SECONDS=43200
# "Remember me" replaces the ABSOLUTE ceiling only; idle timeout still applies.
SESSION_REMEMBER_ME_SECONDS=604800
# How long before idle expiry the client should warn the user.
SESSION_IDLE_WARNING_SECONDS=300
# Max concurrent sessions per user; the oldest is revoked past the limit.
SESSION_MAX_CONCURRENT=5
# Throttle on `last_activity_at` writes so a busy client does not write per request.
SESSION_ACTIVITY_WRITE_INTERVAL_SECONDS=60

# Security scoring (SRS §15). Score starts at 100; bands: 80-100 healthy,
# 50-79 warning, 0-49 high risk.
SESSION_SCORE_NEW_DEVICE_PENALTY=20
SESSION_SCORE_NEW_COUNTRY_PENALTY=20
SESSION_SCORE_TOKEN_REUSE_PENALTY=80
