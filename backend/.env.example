# ---------------------------------------------------------------------------
# AI Agent Control Tower - Environment configuration
# Copy this file to `.env` and adjust the values for your local machine.
# ---------------------------------------------------------------------------

# Human readable project name (shown in Swagger).
PROJECT_NAME=AI Agent Control Tower

# PostgreSQL connection string (local development).
# Format: postgresql+psycopg2://<user>:<password>@<host>:<port>/<database>
DATABASE_URL=postgresql+psycopg2://postgres:<your_password>@localhost:5432/ai_agent_control_tower

# JWT settings. Generate a strong secret for anything beyond local dev, e.g.:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=change-me-in-production-please-use-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# CORS origins (comma separated) for the future dashboard frontend.
BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ---------------------------------------------------------------------------
# Phase 2 settings
# ---------------------------------------------------------------------------

# Prefix used for agent API keys (e.g. agt_live_xxxxx).
API_KEY_PREFIX=agt_live_

# Email notifications (SMTP). Disabled by default for local dev: when false,
# notifications are logged instead of sent. Use Mailtrap for development.
NOTIFICATIONS_ENABLED=false
SMTP_HOST=sandbox.smtp.mailtrap.io
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=no-reply@control-tower.local
SMTP_USE_TLS=true

# ---------------------------------------------------------------------------
# Phase 4.2.2.2 settings — session lifecycle (SRS §11, §12)
# ---------------------------------------------------------------------------

# Idle timeout: no request for this long and the session becomes unusable.
SESSION_IDLE_TIMEOUT_SECONDS=1800
# Absolute ceiling, regardless of activity.
SESSION_ABSOLUTE_TIMEOUT_SECONDS=43200
# "Remember me" replaces the ABSOLUTE ceiling only; idle timeout still applies.
SESSION_REMEMBER_ME_SECONDS=604800
# How long before idle expiry the client should warn the user.
SESSION_IDLE_WARNING_SECONDS=300
# Max concurrent sessions per user; the oldest is revoked past the limit.
SESSION_MAX_CONCURRENT=5
# Throttle on `last_activity_at` writes so a busy client does not write per request.
SESSION_ACTIVITY_WRITE_INTERVAL_SECONDS=60

# Security scoring (SRS §15). Score starts at 100; bands: 80-100 healthy,
# 50-79 warning, 0-49 high risk.
SESSION_SCORE_NEW_DEVICE_PENALTY=20
SESSION_SCORE_NEW_COUNTRY_PENALTY=20
SESSION_SCORE_TOKEN_REUSE_PENALTY=80

# ---------------------------------------------------------------------------
# Phase 4.2.2.3.1 - registration, invitations & rate limiting
# ---------------------------------------------------------------------------

# Public URL the invitation / verification links point at. Must match the SPA.
APP_BASE_URL=http://localhost:5173

# Invitation links: 7 days, single use, hashed at rest.
INVITATION_TTL_SECONDS=604800
# Email verification links: 24 hours, single use, hashed at rest.
EMAIL_VERIFICATION_TTL_SECONDS=86400

# Rate limiting for public endpoints (register, verify-email, resend-verification,
# invitation preview). Postgres-backed fixed window; no Redis (see ADR-0002).
RATE_LIMIT_ENABLED=true
RATE_LIMIT_DEFAULT_REQUESTS=5
RATE_LIMIT_DEFAULT_WINDOW_SECONDS=60

# Honour X-Forwarded-For ONLY behind a proxy you control. Trusting it
# unconditionally lets any caller spoof their rate-limit bucket with a header.
TRUST_PROXY_HEADERS=false

# Rows of globally-stale rate-limit history reaped per request (bounded work, so a
# caller rotating IP addresses cannot leave rate_limit_hits growing for ever).
RATE_LIMIT_SWEEP_BATCH=50

# Where suppressed emails are written when NOTIFICATIONS_ENABLED=false. An onboarding
# email carries the ONLY copy of a single-use token (the DB stores just its SHA-256),
# so the body is appended here instead of being discarded. Git-ignored; never produced
# by a deployment that actually sends mail.
EMAIL_DEV_OUTBOX_PATH=var/dev-outbox.log

# --- Phase 4.2.2.3.2: password policy & credential management ---
# Reject reuse of the last N password hashes (§10).
PASSWORD_HISTORY_DEPTH=10
# Password expiry in days; 0 disables (§11).
PASSWORD_MAX_AGE_DAYS=90
# A password cannot be changed again within this window (§6) — stops history cycling.
PASSWORD_MIN_AGE_HOURS=24
# Admin-issued temporary passwords expire this soon and force a first-login change (§12).
TEMP_PASSWORD_TTL_HOURS=24
# Changing a password revokes the user's other sessions by default (§15).
PASSWORD_CHANGE_REVOKES_SESSIONS=true

# --- Phase 4.2.2.3.3: password reset, recovery & email change ---
# Reset tokens are short-lived (§8): 30 minutes.
PASSWORD_RESET_TTL_SECONDS=1800
# Kill-switch for the whole forgot-password flow (§25).
PASSWORD_RESET_ENABLED=true
# Email-change confirmation token lifetime (§8): 24 hours.
EMAIL_CHANGE_TTL_SECONDS=86400
# A successful reset revokes every session, including remembered devices (§13).
PASSWORD_RESET_REVOKES_SESSIONS=true

# --- Phase 4.2.2.3.4: account protection & risk-based authentication ---
ACCOUNT_PROTECTION_ENABLED=true
# Failures within the window that trip a lock, and the window itself (§8).
PROTECTION_FAILED_THRESHOLD=5
PROTECTION_LOCKOUT_WINDOW_SECONDS=900
# Brute-force / credential-stuffing thresholds within the window (§9).
PROTECTION_BRUTEFORCE_IP_THRESHOLD=20
PROTECTION_STUFFING_DISTINCT_ACCOUNTS=5
# Different-country-within-N-seconds → impossible travel (§13).
PROTECTION_IMPOSSIBLE_TRAVEL_SECONDS=7200
# Risk-score thresholds → decision (§14): challenge / lock / block.
PROTECTION_RISK_CHALLENGE_AT=51
PROTECTION_RISK_LOCK_AT=76
PROTECTION_RISK_BLOCK_AT=91
# CAPTCHA seam (§28) — no live provider yet.
PROTECTION_CAPTCHA_ENABLED=false

# --- Phase 4.2.2.3.5: HTTP hardening (integration §15, §16, §23) ---
# Security response headers on every response. Turn off only if a reverse proxy
# already injects them, to avoid duplicates.
SECURITY_HEADERS_ENABLED=true
# The API serves JSON, so a deny-by-default CSP is safe (the SPA is served separately).
SECURITY_CSP=default-src 'none'; frame-ancestors 'none'
# HSTS only makes sense over TLS — leave off for local http on :8002, enable in prod.
SECURITY_HSTS_ENABLED=false
# Request-correlation header carried in and echoed out (generated if the client omits it).
REQUEST_ID_HEADER=X-Request-ID
